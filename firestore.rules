rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /ramps/{rampId} {

      // Public can only read approved reports. The admin account can
      // read everything, including pending, for the moderation queue.
      allow read: if resource.data.status == "approved"
        || (request.auth != null && request.auth.token.email == "YOUR_ADMIN_EMAIL_HERE");

      // Only signed-in (including anonymous) users can create a report,
      // and only with valid, bounded data. Every new report lands as
      // "pending", nothing goes public until approved in /admin.
      allow create: if request.auth != null
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 4
        && request.resource.data.name.size() < 200
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.lat is number
        && request.resource.data.lng is number
        && request.resource.data.lat >= -90 && request.resource.data.lat <= 90
        && request.resource.data.lng >= -180 && request.resource.data.lng <= 180
        && (!("note" in request.resource.data) || request.resource.data.note.size() < 1000)
        && (!("address" in request.resource.data) || request.resource.data.address.size() < 300)
        && (!("photoUrl" in request.resource.data) || (request.resource.data.photoUrl is string && request.resource.data.photoUrl.size() < 600));

      // Only the admin account can change status (approve/reject), and
      // only the status field, nothing else about the report.
      allow update: if request.auth != null
        && request.auth.token.email == "YOUR_ADMIN_EMAIL_HERE"
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status"])
        && request.resource.data.status in ["approved", "rejected"];

      allow delete: if false;
    }
  }
}
